       &lt;width&gt;0&lt;/width&gt;
       &lt;height&gt;100&lt;/height&gt;
      &lt;/size&gt;
     &lt;/property&gt;
     &lt;property name=&quot;styleSheet&quot;&gt;
      &lt;string notr=&quot;true&quot;&gt;background-color: #e0f7fa; border: 3px dashed #00bcd4; border-radius: 10px;&lt;/string&gt;
     &lt;/property&gt;
     &lt;property name=&quot;text&quot;&gt;
      &lt;string&gt;Drop folders/files here or click to browse...&lt;/string&gt;
     &lt;/property&gt;
    &lt;/widget&gt;
   &lt;/item&gt;
   &lt;item&gt;
    &lt;layout class=&quot;QHBoxLayout&quot; name=&quot;horizontalLayout&quot;&gt;
